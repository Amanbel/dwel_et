{
  "manifest_version": 3,
  "name": "DWEL Content Collector",
  "version": "1.0.0",
  "description": "Collects lightweight social content metadata and sends it to the DWEL backend.",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": ["http://localhost:3000/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://www.tiktok.com/*", "https://www.instagram.com/*", "https://twitter.com/*", "https://x.com/*", "https://www.facebook.com/*", "https://www.reddit.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DWEL"
  }
}
